# ============================================================
# VARIÁVEIS DE AMBIENTE — lead-scoring-saude-clone-Multiplan-
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA faça commit do arquivo .env com valores reais.
# ============================================================

# ------ Banco de Dados (Supabase / PostgreSQL) ------
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE

# ------ OAuth Manus ------
VITE_APP_ID=seu_app_id_aqui
OAUTH_SERVER_URL=https://oauth.manus.im
VITE_OAUTH_PORTAL_URL=https://login.manus.im

# ------ Autenticação JWT ------
JWT_SECRET=sua_chave_jwt_secreta_aqui_minimo_32_caracteres

# ------ Webhooks de Integrações ------
BOTCONVERSA_WEBHOOK_URL=https://new-backend.botconversa.com.br/api/v1/webhooks-automation/catch/SEU_ID/SEU_TOKEN/
GOOGLE_SHEETS_WEBHOOK_URL=https://script.google.com/macros/s/SEU_SCRIPT_ID/exec

# ------ Supabase (acesso direto via SDK) ------
SUPABASE_URL=https://SEU_PROJETO.supabase.co
SUPABASE_ANON_KEY=sua_anon_key_supabase_aqui

# ------ Facebook Pixel / CAPI (opcional) ------
FB_PIXEL_ID=
FB_CAPI_TOKEN=

# ------ Configurações do Site ------
SITE_URL=https://seu-dominio.com.br

# ------ Manus API (opcional) ------
BUILT_IN_FORGE_API_KEY=
BUILT_IN_FORGE_API_URL=

# ------ Identificação do Dono (Dashboard) ------
OWNER_NAME=Seu Nome
OWNER_OPEN_ID=seu_open_id_manus
